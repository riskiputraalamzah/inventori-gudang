# Database connection for Prisma CLI and runtime
# Untuk development lokal atau Vercel Postgres
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# PENTING: Untuk Vercel + Neon Production
# 1. Gunakan endpoint POOLED (-pooler) untuk serverless:
#    postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
#
# 2. JANGAN gunakan channel_binding=require (tidak didukung @neondatabase/serverless)
#    ❌ SALAH: ?sslmode=require&channel_binding=require
#    ✅ BENAR: ?sslmode=require
#
# 3. Pastikan URL menggunakan endpoint -pooler, bukan endpoint direct:
#    ❌ SALAH: ep-xxx.region.aws.neon.tech
#    ✅ BENAR: ep-xxx-pooler.region.aws.neon.tech

# Untuk production di Vercel, gunakan Vercel Postgres environment variables
# POSTGRES_URL akan otomatis tersedia di Vercel

# Khusus test integrasi lokal. Gunakan database kosong terpisah, bukan development/production.
# TEST_DATABASE_URL="postgresql://user:password@localhost:5432/inventori_gudang_test"

# Kunci enkripsi session (ganti dengan string acak 32+ karakter di production)
SESSION_SECRET="ganti-ini-dengan-key-rahasia-production"
